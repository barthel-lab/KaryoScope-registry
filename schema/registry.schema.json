{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/barthel-lab/KaryoScope-registry/schema/registry.schema.json",
  "title": "KaryoScope Registry",
  "type": "object",
  "required": ["schema_version", "databases"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "databases": {
      "type": "array",
      "items": { "$ref": "#/$defs/database" }
    },
    "community_databases": {
      "type": "array",
      "items": { "$ref": "#/$defs/database" }
    }
  },
  "$defs": {
    "database": {
      "type": "object",
      "required": [
        "id", "title", "version", "karyoscope_min_version",
        "taxonomy", "kmer", "feature_sets",
        "size_gb", "source", "url", "sha256"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_]+$" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "release_date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$|^TBD$"
        },
        "karyoscope_min_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "default": { "type": "boolean" },
        "taxonomy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["genus", "species"],
            "properties": {
              "genus": { "type": "string" },
              "species": { "type": "string" },
              "common_name": { "type": "string" },
              "ncbi_taxid": { "type": "integer" }
            }
          }
        },
        "kmer": {
          "type": "object",
          "required": ["size", "type", "max_size"],
          "properties": {
            "size": { "type": "integer", "minimum": 1 },
            "type": { "enum": ["fixed", "variable"] },
            "max_size": { "type": "integer", "minimum": 1 }
          }
        },
        "feature_sets": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "roles": {
          "type": "object",
          "description": "Optional. Maps conceptual roles to feature_set names. Consumed only by the scaffold, centromeres, and karyotype commands. Databases intended only for annotate/bin (e.g. cytoband) may omit this section.",
          "properties": {
            "chromosome_assignment": { "type": "string" },
            "region_assignment": { "type": "string" },
            "centromere_detection": { "type": "string" }
          }
        },
        "smoothing": {
          "type": "object",
          "properties": {
            "recommended_window_bp": { "type": "integer", "minimum": 0 }
          }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "size_gb": { "type": "number", "minimum": 0 },
        "source": { "type": "string" },
        "doi": { "type": "string" },
        "concept_doi": { "type": "string" },
	"url": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$|^PLACEHOLDER$" },
        "citation": { "type": "string" },
        "maintained_by": { "type": "string" }
      }
    }
  }
}
